{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/sutoutaiga/code-explainer/hooks/log-action.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/sutoutaiga/code-explainer/hooks/log-prompt.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/sutoutaiga/code-explainer/hooks/log-assistant.js"
          }
        ]
      }
    ]
  }
}
